# Server configuration
PORT=3000
NODE_ENV=development

# Authentication
JWT_SECRET=replace-with-a-long-random-secret

# Database (PostgreSQL connection string)
# On Railway, this is provided automatically by the Postgres plugin as ${{Postgres.DATABASE_URL}}
DATABASE_URL=postgres://user:password@localhost:5432/dgminutes

# Gemini configuration (used by /api/analyze-image)
GEMINI_API_KEY=replace-with-your-gemini-api-key

# CORS — set this to your frontend URL in production
# Example: https://dgminutes-frontend.up.railway.app
# Multiple origins can be comma-separated. Use * to allow all (not recommended in production).
CORS_ORIGIN=*
